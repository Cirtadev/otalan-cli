{
  "name": "@otalan/cli",
  "version": "1.0.0",
  "description": "Otalan CLI for bundling and publishing OTA updates.",
  "type": "module",
  "bin": {
    "otalan": "./src/bin.ts"
  },
  "scripts": {
    "build": "bun build ./src/bin.ts --target bun --outdir ./dist",
    "compile:macos": "bun build --compile --minify --bytecode --target=bun-darwin-arm64 ./src/bin.ts --outfile ./dist/bin.macos-arm64",
    "compile:linux": "bun build --compile --minify --bytecode --target=bun-linux-x64 ./src/bin.ts --outfile ./dist/bin.linux-x64",
    "compile:windows": "bun build --compile --minify --bytecode --target=bun-windows-x64 ./src/bin.ts --outfile ./dist/bin.windows-x64",
    "compile:all": "bun run compile:macos && bun run compile:linux && bun run compile:windows",
    "check": "tsc -p tsconfig.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "fflate": "^0.8.2",
    "zod": "^4.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@types/bun": "^1.3.0",
    "eslint": "^9.24.0",
    "globals": "^16.4.0",
    "typescript-eslint": "^8.46.1",
    "typescript": "^5.8.0"
  }
}