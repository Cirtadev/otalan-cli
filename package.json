{
  "name": "@otalan/cli",
  "version": "1.4.1",
  "description": "Otalan CLI for bundling and publishing OTA updates through otalan.com.",
  "license": "Apache-2.0",
  "author": {
    "name": "Cirtadev",
    "url": "https://github.com/Cirtadev"
  },
  "keywords": [
    "otalan",
    "ota",
    "cli",
    "capacitor",
    "expo",
    "codepush"
  ],
  "homepage": "https://otalan.com",
  "bugs": {
    "url": "https://github.com/Cirtadev/otalan-cli/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Cirtadev/otalan-cli.git"
  },
  "type": "module",
  "engines": {
    "bun": ">=1.3.11"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/bin.js",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "NOTICE",
    "third-party-licenses.txt"
  ],
  "bin": {
    "otalan": "./dist/bin.js"
  },
  "scripts": {
    "prepublishOnly": "bun test && bun run check && bun run lint",
    "prepack": "bun run build",
    "build": "bun build ./src/bin.ts --target bun --outdir ./dist --minify",
    "compile:macos": "bun build --compile --minify --target=bun-darwin-arm64 ./src/bin.ts --outfile ./dist/bin.macos-arm64",
    "compile:linux": "bun build --compile --minify --target=bun-linux-x64 ./src/bin.ts --outfile ./dist/bin.linux-x64",
    "compile:windows": "bun build --compile --minify --target=bun-windows-x64 ./src/bin.ts --outfile ./dist/bin.windows-x64",
    "compile:all": "bun run compile:macos && bun run compile:linux && bun run compile:windows",
    "pack:dry-run": "bun pm pack --dry-run",
    "test": "bun test",
    "check": "tsc -p tsconfig.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "fflate": "^0.8.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/bun": "^1.3.14",
    "eslint": "^10.4.0",
    "jiti": "^2.7.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4"
  }
}
